{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Product in store inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "sizes": {
          "type": "array"
        },
        "colors": {
          "type": "array"
        }
      },
      "required": ["id", "name", "price", "description", "image", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A transaction order made via webstore or POS",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "items": {
          "type": "array"
        },
        "total": { "type": "number" },
        "type": { "type": "string", "enum": ["ONLINE", "POS"] },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "COMPLETED", "CANCELLED"] },
        "cashReceived": { "type": "number" },
        "changeAmount": { "type": "number" }
      },
      "required": ["id", "date", "items", "total", "type", "customerName", "status"]
    },
    "StoreConfig": {
      "title": "StoreConfig",
      "description": "Global store configuration and settings",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "address": { "type": "string" },
        "currencySymbol": { "type": "string" },
        "taxRate": { "type": "number" },
        "adminPassword": { "type": "string" }
      },
      "required": ["storeName", "whatsappNumber", "address", "currencySymbol", "taxRate"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with role details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["OWNER", "ADMIN", "CASHIER", "CUSTOMER"] },
        "avatarUrl": { "type": "string" }
      },
      "required": ["name", "phone", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store inventory products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Store online and POS transaction records"
    },
    "/config/settings": {
      "schema": "StoreConfig",
      "description": "Store setting configurations"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Registered user profiles"
    }
  }
}
